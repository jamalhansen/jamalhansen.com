#!/bin/bash
# Simplified wrapper for creating new Hugo posts from Obsidian
# Usage: ./new-post path/to/obsidian-note.md [slug] [vault-path]

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# Use environment variable or fallback
if [ -n "$OBSIDIAN_VAULT_PATH" ]; then
    DEFAULT_VAULT_PATH="$OBSIDIAN_VAULT_PATH"
else
    DEFAULT_VAULT_PATH="$HOME/Documents/ObsidianVault"
fi

# Check if we have enough arguments
if [ $# -lt 1 ]; then
    echo "Usage: ./new-post <obsidian-file> [slug] [vault-path]"
    echo ""
    echo "Examples:"
    echo "  ./new-post my-note.md"
    echo "  ./new-post jamalhansen.com/_drafts/my-post.md my-custom-slug"
    echo ""
    exit 1
fi

OBSIDIAN_FILE="$1"
# If 2nd arg is provided and doesn't look like a path (no /), treat as slug
if [ -n "$2" ] && [[ ! "$2" == *"/"* ]] && [[ ! "$2" == "."* ]]; then
    POST_SLUG="$2"
    VAULT_PATH="${3:-$DEFAULT_VAULT_PATH}"
else
    # Extract post slug from filename (remove .md extension and slugify)
    POST_SLUG=$(basename "$OBSIDIAN_FILE" .md | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
    VAULT_PATH="${2:-$DEFAULT_VAULT_PATH}"
fi

# If OBSIDIAN_FILE is not an absolute path, prepend the vault path
if [[ ! "$OBSIDIAN_FILE" = /* ]]; then
    OBSIDIAN_FILE="$VAULT_PATH/$OBSIDIAN_FILE"
fi

echo "🚀 Creating new Hugo post from Obsidian note..."
echo "📄 Source: $OBSIDIAN_FILE"
echo "🏷️  Slug: $POST_SLUG"
echo "📁 Vault: $VAULT_PATH"
echo ""

# Check if the source file exists
if [ ! -f "$OBSIDIAN_FILE" ]; then
    echo "❌ Error: File not found: $OBSIDIAN_FILE"
    exit 1
fi

# Run the Python script
python3 "$SCRIPT_DIR/obsidian-to-hugo.py" "$OBSIDIAN_FILE" "$POST_SLUG" "$VAULT_PATH"
